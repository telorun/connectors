{
  "name": "@telorun/s3",
  "version": "0.5.2",
  "description": "Telo S3 module - AWS S3 resource kinds for Telo manifests.",
  "keywords": [
    "telo",
    "s3",
    "aws",
    "storage"
  ],
  "author": "Bartosz Pasiński <bartosz.pasinski@codenet.pl>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telorun/connectors.git",
    "directory": "aws/s3/nodejs"
  },
  "homepage": "https://github.com/telorun/connectors#readme",
  "bugs": {
    "url": "https://github.com/telorun/connectors/issues"
  },
  "type": "module",
  "exports": {
    "./s3-bucket": {
      "import": "./dist/s3-bucket-controller.js"
    },
    "./s3-list": {
      "import": "./dist/s3-list-controller.js"
    },
    "./s3-put": {
      "import": "./dist/s3-put-controller.js"
    },
    "./s3-get": {
      "import": "./dist/s3-get-controller.js"
    },
    "./s3-delete": {
      "import": "./dist/s3-delete-controller.js"
    },
    "./s3-presigned-url": {
      "import": "./dist/s3-presigned-url-controller.js"
    }
  },
  "files": [
    "dist",
    "src/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "prepack": "cp ../../../LICENSE . && cp ../README.md .",
    "postpack": "rm -f LICENSE && rm -f README.md"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1067.0",
    "@aws-sdk/s3-request-presigner": "^3.1067.0",
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "@telorun/sdk": "^0.50.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@telorun/sdk": "*"
  }
}
